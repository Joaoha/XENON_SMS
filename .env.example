# XENON Stock Management System — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#   # then edit .env
#

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/xenon_sms"

# NextAuth secret (required) — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# Optional: HTTP port exposed by the container (default: 3000)
# PORT=3000

# --- docker-compose only (bundled Postgres) ---
# Password for the bundled Postgres container.
# Leave unset if you supply your own DATABASE_URL above.
# POSTGRES_PASSWORD=changeme
