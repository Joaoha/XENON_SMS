generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  operator
}

enum TransactionType {
  RECEIVE
  HANDOUT
  TRANSFER
}

model User {
  id                  String        @id @default(cuid())
  username            String        @unique
  passwordHash        String
  role                Role          @default(operator)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  transactions        Transaction[]
  deletedTransactions Transaction[] @relation("DeletedTransactions")
}

model StockItem {
  id                 String         @id @default(cuid())
  sku                String         @unique
  name               String
  description        String?
  unit               String         @default("units")
  warehouseId        String?
  warehouseRowId     String?
  shelfId            String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  warehouse          Warehouse?     @relation(fields: [warehouseId], references: [id])
  warehouseRow       WarehouseRow?  @relation(fields: [warehouseRowId], references: [id])
  shelf              Shelf?         @relation(fields: [shelfId], references: [id])
  transactions       Transaction[]
  stockBalances      StockBalance[]
  profileItems       HandoutProfileItem[]
}

model DataHall {
  id           String        @id @default(cuid())
  name         String
  code         String        @unique
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  rows         Row[]
  transactions Transaction[]
}

model Row {
  id           String        @id @default(cuid())
  dataHallId   String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  dataHall     DataHall      @relation(fields: [dataHallId], references: [id])
  racks        Rack[]
  transactions Transaction[]

  @@unique([dataHallId, name])
}

model Rack {
  id           String        @id @default(cuid())
  rowId        String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  row          Row           @relation(fields: [rowId], references: [id])
  transactions Transaction[]

  @@unique([rowId, name])
}

model StockBalance {
  id          String    @id @default(cuid())
  stockItemId String
  warehouseId String
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stockItem StockItem @relation(fields: [stockItemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([stockItemId, warehouseId])
}

model Warehouse {
  id                      String         @id @default(cuid())
  name                    String
  code                    String         @unique
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  rows                    WarehouseRow[]
  stockItems              StockItem[]
  stockBalances           StockBalance[]
  sourceTransactions      Transaction[]  @relation("SourceWarehouse")
  destinationTransactions Transaction[]  @relation("DestinationWarehouse")
}

model WarehouseRow {
  id          String      @id @default(cuid())
  warehouseId String
  name        String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  shelves     Shelf[]
  stockItems  StockItem[]

  @@unique([warehouseId, name])
}

model Shelf {
  id             String       @id @default(cuid())
  warehouseRowId String
  name           String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  warehouseRow   WarehouseRow @relation(fields: [warehouseRowId], references: [id])
  stockItems     StockItem[]

  @@unique([warehouseRowId, name])
}

model HandoutProfile {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       HandoutProfileItem[]
}

model HandoutProfileItem {
  id        String         @id @default(cuid())
  profileId String
  stockItemId String
  quantity  Int
  profile   HandoutProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  stockItem StockItem      @relation(fields: [stockItemId], references: [id])

  @@unique([profileId, stockItemId])
}

model Transaction {
  id                     String          @id @default(cuid())
  type                   TransactionType
  stockItemId            String
  quantity               Int
  userId                 String
  pickedBy               String?
  dataHallId             String?
  rowId                  String?
  rackId                 String?
  sourceWarehouseId      String?
  destinationWarehouseId String?
  notes                  String?
  reference              String?
  batchId                String?
  createdAt              DateTime        @default(now())
  deletedAt              DateTime?
  deletedBy              String?

  stockItem            StockItem  @relation(fields: [stockItemId], references: [id])
  user                 User       @relation(fields: [userId], references: [id])
  dataHall             DataHall?  @relation(fields: [dataHallId], references: [id])
  row                  Row?       @relation(fields: [rowId], references: [id])
  rack                 Rack?      @relation(fields: [rackId], references: [id])
  sourceWarehouse      Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destinationWarehouse Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  deletedByUser        User?      @relation("DeletedTransactions", fields: [deletedBy], references: [id])
}
